# TAR Engine OSS — environment template
# Copy to .env and fill in. Never commit .env to git.

# Engine port
PORT=8765
LOG_LEVEL=INFO

# Default OpenAI-compatible LLM (BYOK)
# Users can override per-request via X-LLM-Api-Key header
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Optional: Telegram bot entry
TELEGRAM_BOT_TOKEN=
TELEGRAM_AUTHORIZED_CHAT_IDS=

# Optional: Knowledge L3 RAG embedding
ENABLE_RAG=false
CHROMA_DB_DIR=./chroma_db
